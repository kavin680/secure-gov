generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Tenant Model ───────────────────────────────────────────────────────────────

model Tenant {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  description String?
  isActive    Boolean  @default(true) @map("is_active")
  settings    Json?
  maxUsers    Int      @default(50) @map("max_users")

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  // Relations
  users       User[]
  auditLogs   AuditLog[]   @relation("TenantAuditLogs")
  webhooks    Webhook[]
  fileUploads FileUpload[]
  notifications Notification[]
  policies    Policy[]
  policyLogs  PolicyLog[]
  aiLogs      AiLog[]
  apiKeys     ApiKey[]
  documents   Document[]

  @@index([slug])
  @@index([isActive])
  @@map("tenants")
}

// ─── Base User Model ───────────────────────────────────────────────────────────

model User {
  id                  String    @id @default(uuid())
  email               String    @unique
  password            String
  firstName           String    @map("first_name")
  lastName            String    @map("last_name")
  role                Role      @default(USER)
  tenantId            String?   @map("tenant_id")
  isActive            Boolean   @default(true) @map("is_active")
  isEmailVerified     Boolean   @default(false) @map("is_email_verified")
  emailVerificationToken String? @map("email_verification_token")
  passwordResetToken  String?   @map("password_reset_token")
  passwordResetExpires DateTime? @map("password_reset_expires")
  loginAttempts       Int       @default(0) @map("login_attempts")
  lockedUntil         DateTime? @map("locked_until")
  lastLoginAt         DateTime? @map("last_login_at")
  lastLoginIp         String?   @map("last_login_ip")

  // Audit fields
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")
  deletedAt           DateTime? @map("deleted_at")

  // Relations
  tenant              Tenant?   @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  sessions            Session[]
  auditLogs           AuditLog[] @relation("UserAuditLogs")

  @@index([tenantId])
  @@map("users")
}

// ─── Session Model (for refresh token tracking) ────────────────────────────────

model Session {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  refreshToken String   @map("refresh_token")
  userAgent    String?  @map("user_agent")
  ipAddress    String?  @map("ip_address")
  expiresAt    DateTime @map("expires_at")
  isRevoked    Boolean  @default(false) @map("is_revoked")

  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([refreshToken])
  @@map("sessions")
}

// ─── Audit Log Model ───────────────────────────────────────────────────────────

model AuditLog {
  id          String   @id @default(uuid())
  action      String
  resource    String
  resourceId  String?  @map("resource_id")
  userId      String?  @map("user_id")
  tenantId    String?  @map("tenant_id")
  requestId   String?  @map("request_id")
  description String?
  metadata    Json?
  ipAddress   String?  @map("ip_address")
  userAgent   String?  @map("user_agent")
  createdAt   DateTime @default(now()) @map("created_at")

  user        User?    @relation("UserAuditLogs", fields: [userId], references: [id], onDelete: SetNull)
  tenant      Tenant?  @relation("TenantAuditLogs", fields: [tenantId], references: [id], onDelete: SetNull)

  @@index([action])
  @@index([resource])
  @@index([userId])
  @@index([tenantId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ─── Feature Flags ─────────────────────────────────────────────────────────────

model FeatureFlag {
  id          String   @id @default(uuid())
  key         String   @unique
  name        String
  description String?
  enabled     Boolean  @default(false)
  metadata    Json?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([key])
  @@map("feature_flags")
}

// ─── Notifications ─────────────────────────────────────────────────────────────

model Notification {
  id          String             @id @default(uuid())
  userId      String             @map("user_id")
  tenantId    String?            @map("tenant_id")
  type        String
  title       String
  message     String
  data        Json?
  isRead      Boolean            @default(false) @map("is_read")
  readAt      DateTime?          @map("read_at")
  createdAt   DateTime           @default(now()) @map("created_at")

  tenant      Tenant?            @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([tenantId])
  @@index([isRead])
  @@index([createdAt])
  @@map("notifications")
}

// ─── Webhooks ──────────────────────────────────────────────────────────────────

model Webhook {
  id          String   @id @default(uuid())
  name        String
  url         String
  secret      String
  events      String[]
  tenantId    String?  @map("tenant_id")
  isActive    Boolean  @default(true) @map("is_active")
  lastTriggeredAt DateTime? @map("last_triggered_at")
  failureCount Int     @default(0) @map("failure_count")
  createdBy   String   @map("created_by")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant      Tenant?  @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([isActive])
  @@map("webhooks")
}

model WebhookLog {
  id          String   @id @default(uuid())
  webhookId   String   @map("webhook_id")
  event       String
  payload     Json
  statusCode  Int?     @map("status_code")
  response    String?
  success     Boolean  @default(false)
  error       String?
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([webhookId])
  @@index([createdAt])
  @@map("webhook_logs")
}

// ─── File Uploads ──────────────────────────────────────────────────────────────

model FileUpload {
  id          String   @id @default(uuid())
  filename    String
  originalName String  @map("original_name")
  mimeType    String   @map("mime_type")
  size        Int
  storageKey  String   @map("storage_key")
  storageType String   @default("local") @map("storage_type")
  url         String?
  tenantId    String?  @map("tenant_id")
  uploadedBy  String   @map("uploaded_by")
  createdAt   DateTime @default(now()) @map("created_at")

  tenant      Tenant?  @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([uploadedBy])
  @@index([storageKey])
  @@map("file_uploads")
}

// ─── Policies ──────────────────────────────────────────────────────────────────

model Policy {
  id          String       @id @default(uuid())
  tenantId    String       @map("tenant_id")
  name        String
  description String?
  type        PolicyType
  rules       Json
  action      PolicyAction @default(DENY)
  priority    Int          @default(0)
  isActive    Boolean      @default(true) @map("is_active")
  createdBy   String?      @map("created_by")

  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  policyLogs  PolicyLog[]

  @@index([tenantId])
  @@index([type])
  @@index([isActive])
  @@index([priority])
  @@map("policies")
}

model PolicyLog {
  id            String   @id @default(uuid())
  policyId      String   @map("policy_id")
  tenantId      String   @map("tenant_id")
  userId        String?  @map("user_id")
  action        String
  decision      String
  requestPath   String?  @map("request_path")
  requestMethod String?  @map("request_method")
  prompt        String?
  matchedRule   Json?    @map("matched_rule")
  metadata      Json?
  createdAt     DateTime @default(now()) @map("created_at")

  policy        Policy   @relation(fields: [policyId], references: [id], onDelete: Cascade)
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([policyId])
  @@index([tenantId])
  @@index([userId])
  @@index([decision])
  @@index([createdAt])
  @@map("policy_logs")
}

// ─── RAG (Retrieval-Augmented Generation) ───────────────────────────────────────

model Document {
  id            String   @id @default(uuid())
  tenantId      String   @map("tenant_id")
  title         String
  description   String?
  fileName      String   @map("file_name")
  fileType      String   @map("file_type")
  fileSize      Int      @map("file_size")
  storageKey    String   @map("storage_key")
  status        DocumentStatus @default(PENDING)
  totalChunks   Int      @default(0) @map("total_chunks")
  errorMessage  String?  @map("error_message")
  uploadedBy    String   @map("uploaded_by")
  metadata      Json?

  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  chunks        DocumentChunk[]

  @@index([tenantId])
  @@index([status])
  @@index([uploadedBy])
  @@map("documents")
}

model DocumentChunk {
  id            String   @id @default(uuid())
  documentId    String   @map("document_id")
  chunkIndex    Int      @map("chunk_index")
  content       String
  tokenCount    Int?     @map("token_count")
  embedding     Unsupported("vector(1536)")?

  createdAt     DateTime @default(now()) @map("created_at")

  document      Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
  @@map("document_chunks")
}

// ─── AI Gateway ─────────────────────────────────────────────────────────────────

model AiLog {
  id              String    @id @default(uuid())
  tenantId        String    @map("tenant_id")
  userId          String?   @map("user_id")
  provider        String
  model           String
  prompt          String
  response        String?
  systemPrompt    String?   @map("system_prompt")
  promptTokens    Int?      @map("prompt_tokens")
  completionTokens Int?     @map("completion_tokens")
  totalTokens     Int?      @map("total_tokens")
  latencyMs       Int?      @map("latency_ms")
  status          AiRequestStatus @default(PENDING)
  errorMessage    String?   @map("error_message")
  policyDecision  String?   @map("policy_decision")
  policyId        String?   @map("policy_id")
  metadata        Json?
  cost            Float?

  createdAt       DateTime  @default(now()) @map("created_at")

  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([userId])
  @@index([provider])
  @@index([status])
  @@index([createdAt])
  @@map("ai_logs")
}

model ApiKey {
  id          String   @id @default(uuid())
  tenantId    String   @map("tenant_id")
  name        String
  provider    String
  keyHash     String   @map("key_hash")
  keyPrefix   String   @map("key_prefix")
  isActive    Boolean  @default(true) @map("is_active")
  lastUsedAt  DateTime? @map("last_used_at")
  createdBy   String   @map("created_by")

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, provider])
  @@index([tenantId])
  @@index([isActive])
  @@map("api_keys")
}

// ─── Enums ──────────────────────────────────────────────────────────────────────

enum Role {
  USER
  ADMIN
  TENANT_ADMIN
  DEVELOPER
  SUPER_ADMIN
}

enum PolicyType {
  KEYWORD_BLOCK
  RATE_LIMIT
  MODEL_RESTRICT
  TOPIC_RESTRICT
  SENSITIVE_DATA
  USAGE_QUOTA
  CUSTOM
}

enum PolicyAction {
  ALLOW
  DENY
  FLAG
  LOG
  RATE_LIMIT
}

enum DocumentStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum AiRequestStatus {
  PENDING
  SUCCESS
  FAILED
  DENIED
  RATE_LIMITED
}
