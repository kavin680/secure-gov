# ─── Production Environment Variables ─────────────────────────────────────────
# Copy to .env.production and fill in all required values.
# Required variables are marked with (REQUIRED).

# ─── Application ──────────────────────────────────────────────────────────────
APP_NAME="Enterprise Backend"
NODE_ENV=production
APP_PORT=3000
API_PREFIX=api
API_VERSION=v1
FRONTEND_URL=https://app.yourdomain.com                      # (REQUIRED)
CORS_ORIGINS=https://app.yourdomain.com

# ─── Database (Managed PostgreSQL with pgvector) ─────────────────────────────
# AWS RDS: postgresql://user:pass@rds-host.region.rds.amazonaws.com:5432/dbname
# GCP Cloud SQL: postgresql://user:pass@/dbname?host=/cloudsql/project:region:instance
DATABASE_URL=                                                 # (REQUIRED)
DATABASE_LOGGING=false

# ─── Authentication ──────────────────────────────────────────────────────────
JWT_SECRET=                                                   # (REQUIRED) min 32 chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=                                           # (REQUIRED) min 32 chars
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_SALT_ROUNDS=12
EMAIL_VERIFICATION_ENABLED=true
PASSWORD_RESET_TOKEN_EXPIRES_IN=3600

# ─── Redis (Managed) ─────────────────────────────────────────────────────────
# AWS ElastiCache: your-cluster.cache.amazonaws.com
# GCP Memorystore: 10.0.0.x
REDIS_ENABLED=true
REDIS_HOST=                                                   # (REQUIRED)
REDIS_PORT=6379
REDIS_PASSWORD=                                               # (REQUIRED if auth enabled)
REDIS_TTL=300
REDIS_KEY_PREFIX=enterprise:

# ─── Mail (SMTP) ─────────────────────────────────────────────────────────────
MAIL_ENABLED=true
MAIL_HOST=                                                    # (REQUIRED) e.g., smtp.sendgrid.net
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=                                                    # (REQUIRED)
MAIL_PASSWORD=                                                # (REQUIRED)
MAIL_FROM="Enterprise App <noreply@yourdomain.com>"

# ─── Queue ────────────────────────────────────────────────────────────────────
QUEUE_ENABLED=true
QUEUE_REMOVE_ON_COMPLETE=100
QUEUE_REMOVE_ON_FAIL=50
QUEUE_DEFAULT_ATTEMPTS=3

# ─── Monitoring / Observability ───────────────────────────────────────────────
MONITORING_ENABLED=true
MONITORING_PROVIDER=sentry                                    # sentry | datadog | none
SENTRY_DSN=                                                   # (REQUIRED if sentry)
DATADOG_API_KEY=                                              # (REQUIRED if datadog)
METRICS_PORT=9090

# ─── Storage (S3-compatible) ─────────────────────────────────────────────────
STORAGE_TYPE=s3
S3_BUCKET=                                                    # (REQUIRED)
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=                                             # (REQUIRED)
S3_SECRET_ACCESS_KEY=                                         # (REQUIRED)
S3_CDN_URL=                                                   # Optional CloudFront URL

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=info
